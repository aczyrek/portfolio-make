            "version": 1,
            "parameters": {},
            "mapper": {
                "input": [
                    {
                        "name": "salesTeam",
                        "value": "{{15.body.data}}"
                    },
                    {
                        "name": "targetEmail",
                        "value": "{{1.user.email}}"
                    }
                ],
                "language": "javascript",
                "inputFormat": "editor",
                "dependencies": [],
                "codeEditorJavascript": "const { salesTeam, targetEmail } = input;\n\nlet matchedSalesman = salesTeam.find(person => person.email_address === targetEmail);\n\nlet salesmanId = null;\n\nif (!matchedSalesman) {\n    matchedSalesman = salesTeam.find(person => person.email_address === \"b.pawlowicz@tisagroup.ch\");\n}\n\nif (matchedSalesman) {\n    salesmanId = matchedSalesman.id.workspace_member_id;\n} else {\n    throw new Error(`Salesman with email ${targetEmail} was not found in Attio.`);\n}\n\nreturn {\n    salesman_id: salesmanId\n};"
            },
            "metadata": {
                "designer": {
                    "x": 600,
                    "y": 0
                },
                "restore": {
                    "expect": {
                        "input": {
                            "items": [
                                null,
                                null
                            ]
                        },
                        "language": {
                            "mode": "chose",
                            "label": "JavaScript"
                        },
                        "inputFormat": {
                            "label": "Code editor"
                        }
                    }
                },
                "expect": [
